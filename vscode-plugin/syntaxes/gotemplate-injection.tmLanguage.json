{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Go Template Actions (Muxt)",
  "scopeName": "source.gotemplate.muxt",
  "injectionSelector": "L:text.html.gohtml -comment -meta.embedded.block.gotemplate",
  "patterns": [
    { "include": "#comment" },
    { "include": "#named-template-action" },
    { "include": "#action" }
  ],
  "repository": {
    "comment": {
      "name": "comment.block.gotemplate",
      "begin": "\\{\\{-?\\s*/\\*",
      "end": "\\*/\\s*-?\\}\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.begin.gotemplate" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.end.gotemplate" }
      }
    },
    "named-template-action": {
      "name": "meta.embedded.block.gotemplate meta.action.named-template.gotemplate",
      "begin": "(\\{\\{)(-)?\\s*(define|block|template)\\s+",
      "beginCaptures": {
        "1": { "name": "punctuation.section.embedded.begin.gotemplate" },
        "2": { "name": "keyword.operator.trim.gotemplate" },
        "3": { "name": "keyword.control.gotemplate" }
      },
      "end": "(-)?(\\}\\})",
      "endCaptures": {
        "1": { "name": "keyword.operator.trim.gotemplate" },
        "2": { "name": "punctuation.section.embedded.end.gotemplate" }
      },
      "patterns": [
        { "include": "#template-name" },
        { "include": "#action-content" }
      ]
    },
    "template-name": {
      "patterns": [
        {
          "comment": "Mirrors muxt templateNameMux: ^(?P<pattern>((?P<METHOD>[A-Z]+)\\s+)?(?P<HOST>([^/])*)(?P<PATH>(/(\\S)*)))(\\s+(?P<HTTP_STATUS>(\\d|http\\.Status)\\S+))?(?P<CALL>.*)?$ — anchored to the quoted name instead of ^/$.",
          "name": "string.quoted.double.template-name.muxt-route.gotemplate",
          "match": "\\G(\")((([A-Z]+)\\s+)?([^/\"]*)(/[^\"\\s]*))(\\s+((?:\\d|http\\.Status)[^\"\\s]+))?([^\"]*)(\")",
          "captures": {
            "1": { "name": "punctuation.definition.string.begin.gotemplate" },
            "4": {
              "patterns": [
                {
                  "match": "\\b(GET|POST|PUT|PATCH|DELETE)\\b",
                  "name": "keyword.control.http-method.muxt"
                },
                {
                  "match": "[A-Z]+",
                  "name": "invalid.illegal.http-method.muxt"
                }
              ]
            },
            "5": { "name": "entity.name.namespace.host.muxt" },
            "6": { "patterns": [{ "include": "#muxt-path" }] },
            "8": {
              "patterns": [
                {
                  "match": "http\\.Status[A-Za-z]+",
                  "name": "support.constant.http-status.muxt"
                },
                {
                  "match": "\\d+",
                  "name": "constant.numeric.http-status.muxt"
                }
              ]
            },
            "9": { "patterns": [{ "include": "#muxt-call" }] },
            "10": { "name": "punctuation.definition.string.end.gotemplate" }
          }
        },
        {
          "comment": "Raw-string (backtick) variant of the muxt route name rule.",
          "name": "string.quoted.raw.template-name.muxt-route.gotemplate",
          "match": "\\G(`)((([A-Z]+)\\s+)?([^/`]*)(/[^`\\s]*))(\\s+((?:\\d|http\\.Status)[^`\\s]+))?([^`]*)(`)",
          "captures": {
            "1": { "name": "punctuation.definition.string.begin.gotemplate" },
            "4": {
              "patterns": [
                {
                  "match": "\\b(GET|POST|PUT|PATCH|DELETE)\\b",
                  "name": "keyword.control.http-method.muxt"
                },
                {
                  "match": "[A-Z]+",
                  "name": "invalid.illegal.http-method.muxt"
                }
              ]
            },
            "5": { "name": "entity.name.namespace.host.muxt" },
            "6": { "patterns": [{ "include": "#muxt-path" }] },
            "8": {
              "patterns": [
                {
                  "match": "http\\.Status[A-Za-z]+",
                  "name": "support.constant.http-status.muxt"
                },
                {
                  "match": "\\d+",
                  "name": "constant.numeric.http-status.muxt"
                }
              ]
            },
            "9": { "patterns": [{ "include": "#muxt-call" }] },
            "10": { "name": "punctuation.definition.string.end.gotemplate" }
          }
        },
        {
          "name": "string.quoted.double.template-name.gotemplate",
          "match": "\\G(\")([^\"]*)(\")",
          "captures": {
            "1": { "name": "punctuation.definition.string.begin.gotemplate" },
            "3": { "name": "punctuation.definition.string.end.gotemplate" }
          }
        },
        {
          "name": "string.quoted.raw.template-name.gotemplate",
          "match": "\\G(`)([^`]*)(`)",
          "captures": {
            "1": { "name": "punctuation.definition.string.begin.gotemplate" },
            "3": { "name": "punctuation.definition.string.end.gotemplate" }
          }
        }
      ]
    },
    "muxt-path": {
      "patterns": [
        {
          "match": "(\\{)([^}]*?)(\\.\\.\\.)?(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.variable.begin.path.muxt" },
            "2": { "name": "variable.parameter.path.muxt" },
            "3": { "name": "keyword.operator.variadic.path.muxt" },
            "4": { "name": "punctuation.definition.variable.end.path.muxt" }
          }
        },
        {
          "match": "/",
          "name": "punctuation.separator.path.muxt"
        },
        {
          "match": "[^/{]+",
          "name": "string.other.path.muxt"
        }
      ]
    },
    "muxt-call": {
      "patterns": [
        {
          "match": "([A-Za-z_][A-Za-z0-9_]*)(?=\\()",
          "name": "entity.name.function.call.muxt"
        },
        {
          "match": "\\b(ctx|request|response|form|err)\\b",
          "name": "variable.language.call-arg.muxt"
        },
        {
          "match": "[A-Za-z_][A-Za-z0-9_]*",
          "name": "variable.parameter.call-arg.muxt"
        },
        {
          "match": "[()]",
          "name": "punctuation.section.parens.call.muxt"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.call.muxt"
        }
      ]
    },
    "action": {
      "name": "meta.embedded.block.gotemplate",
      "begin": "(\\{\\{)(-)?",
      "beginCaptures": {
        "1": { "name": "punctuation.section.embedded.begin.gotemplate" },
        "2": { "name": "keyword.operator.trim.gotemplate" }
      },
      "end": "(-)?(\\}\\})",
      "endCaptures": {
        "1": { "name": "keyword.operator.trim.gotemplate" },
        "2": { "name": "punctuation.section.embedded.end.gotemplate" }
      },
      "patterns": [{ "include": "#action-content" }]
    },
    "action-content": {
      "patterns": [
        { "include": "#string" },
        { "include": "#raw-string" },
        { "include": "#rune" },
        {
          "match": "\\b(if|else|range|with|end|template|define|block|break|continue)\\b",
          "name": "keyword.control.gotemplate"
        },
        {
          "match": "\\b(and|call|html|index|slice|js|len|not|or|print|printf|println|urlquery|eq|ne|lt|le|gt|ge)\\b",
          "name": "support.function.builtin.gotemplate"
        },
        {
          "match": "\\b(true|false|nil)\\b",
          "name": "constant.language.gotemplate"
        },
        {
          "match": "\\$[A-Za-z_][A-Za-z0-9_]*",
          "name": "variable.other.gotemplate"
        },
        {
          "match": "\\$",
          "name": "variable.language.dollar.gotemplate"
        },
        {
          "match": "(\\.)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "punctuation.accessor.gotemplate" },
            "2": { "name": "variable.other.member.gotemplate" }
          }
        },
        {
          "match": "\\.(?![A-Za-z0-9_.])",
          "name": "variable.language.dot.gotemplate"
        },
        {
          "match": ":=",
          "name": "keyword.operator.assignment.gotemplate"
        },
        {
          "match": "\\|",
          "name": "keyword.operator.pipe.gotemplate"
        },
        {
          "match": "\\b(0[xX][0-9A-Fa-f_]+|\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?)\\b",
          "name": "constant.numeric.gotemplate"
        },
        {
          "match": "[()]",
          "name": "punctuation.section.group.gotemplate"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.gotemplate"
        }
      ]
    },
    "string": {
      "name": "string.quoted.double.gotemplate",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.gotemplate" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.gotemplate" }
      },
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.gotemplate"
        }
      ]
    },
    "raw-string": {
      "name": "string.quoted.raw.gotemplate",
      "begin": "`",
      "end": "`",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.gotemplate" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.gotemplate" }
      }
    },
    "rune": {
      "match": "'(?:\\\\.|[^'\\\\])'",
      "name": "constant.other.rune.gotemplate"
    }
  }
}